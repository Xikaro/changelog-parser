{
  "name": "action-changelog-parser",
  "version": "1.2.2",
  "description": "Github action that parses changelog",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xikaro/action-changelog-parser.git"
  },
  "keywords": [
    "actions",
    "changelog-parser",
    "changelog"
  ],
  "author": "xikaro",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/xikaro/action-changelog-parser/issues"
  },
  "homepage": "https://github.com/xikaro/action-changelog-parser#readme",
  "main": "build/js/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build-cjs": "tsc -p tsconfig-cjs.json",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build build/js/main.js --source-map --out build/dist --license licenses.txt && node scripts/post-package.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "coveralls": "cat ./build/coverage/lcov.info | ./node_modules/coveralls/bin/coveralls.js",
    "ci": "npm run lint && npm run coverage && npm run build && npm run build-cjs && npm run package"
  },
  "dependencies": {
    "@actions/core": "^1.11.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^8.57.1",
    "eslint-plugin-jest": "^28.11.0",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.8.2"
  }
}
